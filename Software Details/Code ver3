# ---------- SERVER ----------
def handle(conn):
    req = conn.recv(512).decode()
    path = req.split(' ')[1]

    if path=='/' or path=='/index.html':
        conn.send('HTTP/1.1 200 OK\r\nContent-Type:text/html\r\n\r\n')
        conn.send(PAGE)

    elif path=='/state':
        data = '{"q":%d,"correct":%d,"wrong":%d,"active":%s}' % (
            q, correct, wrong, 'true' if active else 'false'
        )
        conn.send('HTTP/1.1 200 OK\r\nContent-Type:application/json\r\n\r\n')
        conn.send(data)

    conn.close()

# ---------- MAIN LOOP ----------
while True:

    # web
    try:
        c,_ = server.accept()
        handle(c)
    except:
        pass

    # start game
    if not active:
        if distance() < 20:
            start_game()
        time.sleep(0.2)
        continue

    # touch input
    t = get_touch()

    if t != -1:
        print("Touched:", t)

        if t == answers[q]:
            do_correct()
        else:
            do_wrong()

        time.sleep(0.5)

    time.sleep(0.05)
