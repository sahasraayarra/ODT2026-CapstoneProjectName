import time, network, socket
from machine import Pin, PWM, TouchPad
from neopixel import NeoPixel

trig = Pin(32, Pin.OUT)
echo = Pin(33, Pin.IN)

leds = [Pin(p, Pin.OUT) for p in (18,19,21,22)]

touches = [
    TouchPad(Pin(4)),
    TouchPad(Pin(14)),
    TouchPad(Pin(12)),
    TouchPad(Pin(13))
]

buzzer = PWM(Pin(23))
buzzer.duty(0)

sphinx = PWM(Pin(5), freq=50)
door   = PWM(Pin(26), freq=50)

np = NeoPixel(Pin(15), 16)

#TOUCH
time.sleep(1)
baseline = [t.read() for t in touches]
THRESHOLD = 100

def safe_read(t):
    try:
        return t.read()
    except:
        return 1000

def get_touch():
    for i in range(4):
        if safe_read(touches[i]) < baseline[i] - THRESHOLD:
            time.sleep(0.1)
            return i
    return -1

#FUNCTIONS
def beep(freq, duration):
    buzzer.freq(freq)
    buzzer.duty(512)
    time.sleep(duration)
    buzzer.duty(0)

def set_leds(n):
    for i in range(4):
        leds[i].value(1 if i < n else 0)

def neopixel_fill(r,g,b):
    for i in range(len(np)):
        np[i]=(r,g,b)
    np.write()

def rainbow():
    colors=[(255,0,0),(255,100,0),(255,255,0),
            (0,255,0),(0,0,255),(150,0,255)]
    for _ in range(3):
        for c in colors:
            neopixel_fill(*c)
            time.sleep(0.1)

def nod():
    sphinx.duty(60)
    time.sleep(0.3)
    sphinx.duty(90)
    time.sleep(0.3)
    sphinx.duty(60)

def open_door():
    for d in range(40, 75, 1):
        door.duty(d)
        time.sleep(0.05)

#ULTRASONIC 
def distance():
    trig.off(); time.sleep_us(2)
    trig.on(); time.sleep_us(10)
    trig.off()

    timeout = time.ticks_ms()

    while echo.value()==0:
        if time.ticks_diff(time.ticks_ms(), timeout) > 100:
            return 999
    start=time.ticks_us()

    while echo.value()==1:
        if time.ticks_diff(time.ticks_ms(), timeout) > 100:
            return 999
    end=time.ticks_us()

    return (end-start)/58

#GAME
answers = [1,0,2,3,0,2,1,3]

q = 0
correct = 0
wrong = 0
active = False
last_result = ""

pair_correct = 0
pair_index = 0
led_progress = 0

game_over = False
game_result = ""   

def start_game():
    global q,correct,wrong,active,last_result
    global pair_correct,pair_index,led_progress

    q=0
    correct=0
    wrong=0
    active=True
    last_result=""

    pair_correct=0
    pair_index=0
    led_progress=0

    set_leds(0)
    neopixel_fill(0,0,0)

def evaluate_pair():
    global pair_correct, pair_index, led_progress
    global active, game_over, game_result

    passed = False

    if pair_index < 2:
        if pair_correct >= 1:
            passed = True
    else:
        if pair_correct == 2:
            passed = True

    if passed:
        led_progress += 1
        set_leds(led_progress)
    else:
        active = False
        game_over = True
        game_result = "lose"
        beep(100,1)
        return

    pair_correct = 0
    pair_index += 1

    if led_progress >= 4:
        open_door()
        rainbow()
        beep(1000,0.2); beep(1200,0.2); beep(1400,0.2)
        active = False
        game_over = True
        game_result = "win"

def do_correct():
    global correct,q,last_result,pair_correct
    correct += 1
    pair_correct += 1
    last_result = "correct"

    neopixel_fill(0,255,0)
    beep(800,0.15)

    q += 1

    if q % 2 == 0:
        evaluate_pair()

def do_wrong():
    global wrong,q,last_result
    wrong += 1
    last_result = "wrong"

    neopixel_fill(255,0,0)
    beep(200,0.3)
    nod()

    q += 1

    if q % 2 == 0:
        evaluate_pair()

